<Window x:Class="SystemHardwareAudit.ComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comparison" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <!-- Custom macOS style ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#33FFFFFF" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Border CornerRadius="14" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1C1C1E" Offset="0"/>
                    <GradientStop Color="#141416" Offset="0.5"/>
                    <GradientStop Color="#1A1A1F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" MouseDown="DragWindow_MouseDown" Background="Transparent" Margin="24,20,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- macOS dots -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="12" Height="12" Background="#FF5F57" BorderThickness="0" Margin="0,0,8,0" Cursor="Hand" Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="dot" Background="{TemplateBinding Background}" CornerRadius="6" Opacity="0.85"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="dot" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Width="12" Height="12" Background="#FEBD2F" CornerRadius="6" Opacity="0.85" Margin="0,0,8,0"/>
                        <Border Width="12" Height="12" Background="#28C840" CornerRadius="6" Opacity="0.85"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="Baseline Comparison" Foreground="#99FFFFFF" FontFamily="Segoe UI" FontWeight="Medium" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Summary Bar -->
                <Border Grid.Row="1" Margin="24,18,24,0" Padding="18,12" CornerRadius="10" BorderThickness="1" BorderBrush="#10FFFFFF">
                    <Border.Background>
                        <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
                    </Border.Background>
                    <TextBlock Text="{Binding SummaryText}" Foreground="#AAFFFFFF" FontFamily="Segoe UI" FontWeight="Light" FontSize="13" HorizontalAlignment="Center"/>
                </Border>

                <!-- Column Headers -->
                <Grid Grid.Row="2" Margin="24,18,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Category" Foreground="#55FFFFFF" FontWeight="Medium" FontSize="11" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="1" Text="Field" Foreground="#55FFFFFF" FontWeight="Medium" FontSize="11" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="2" Text="Baseline" Foreground="#55FFFFFF" FontWeight="Medium" FontSize="11" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="3" Text="Current" Foreground="#55FFFFFF" FontWeight="Medium" FontSize="11" FontFamily="Segoe UI"/>
                </Grid>

                <Border Grid.Row="2" Height="1" VerticalAlignment="Bottom" Margin="24,0" Opacity="0.1" Background="White"/>

                <!-- Data Rows -->
                <ScrollViewer Grid.Row="3" Margin="24,10,24,20" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ComparisonItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBorder" Margin="0,0,0,2" Padding="0,10" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#EF4444" Opacity="0.06"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Category}" Foreground="#55FFFFFF" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="#BBFFFFFF" FontSize="12" FontWeight="Medium" FontFamily="Segoe UI" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                        <TextBlock x:Name="txtOld" Grid.Column="2" Text="{Binding OldValue}" Foreground="#77FFFFFF" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="txtNew" Grid.Column="3" Text="{Binding NewValue}" Foreground="#77FFFFFF" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                        <Setter TargetName="txtOld" Property="Foreground" Value="#EF4444"/>
                                        <Setter TargetName="txtOld" Property="TextDecorations" Value="Strikethrough"/>
                                        <Setter TargetName="txtNew" Property="Foreground" Value="#34D399"/>
                                        <Setter TargetName="txtNew" Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</Window>
